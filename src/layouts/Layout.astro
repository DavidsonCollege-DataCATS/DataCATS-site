---
import '../styles/global.css';
import { Image } from 'astro:assets';
import { ClientRouter } from 'astro:transitions';
import davidsonLogo from '../assets/branding/left-aligned-lockup-red and black.png';

interface Props {
  title?: string;
}

const { title = 'Data CATS | Davidson College' } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ClientRouter />
    <script>
      // "Previous"/"Next" consultant links carry data-direction so the swipe
      // animation goes the way the user actually navigated, not always forward.
      document.addEventListener('astro:before-preparation', (event) => {
        const source = event.sourceElement;
        if (source instanceof HTMLElement && source.dataset.direction) {
          event.direction = source.dataset.direction === 'prev' ? 'back' : 'forward';
        }
      });
    </script>
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-900">
    <header class="border-b border-slate-200 bg-white">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
        <a href="/" class="flex items-center gap-3">
          <Image src={davidsonLogo} alt="Davidson College" height={32} class="h-8 w-auto" />
          <span class="text-lg font-bold tracking-tight text-davidson-red">Data CATS</span>
        </a>
        <div class="flex gap-6 text-sm font-medium text-slate-600">
          <a href="/" class="hover:text-davidson-red">Consultants</a>
          <a href="/calendar" class="hover:text-davidson-red">Calendar</a>
        </div>
      </nav>
    </header>
    <main class="mx-auto max-w-6xl px-6 py-10" transition:animate="slide">
      <slot />
    </main>
  </body>
</html>
