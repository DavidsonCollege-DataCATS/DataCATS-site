---
import '../styles/global.css';
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import { ClientRouter } from 'astro:transitions';
import { withBase } from '../lib/url';
import davidsonLogoRedWhite from '../assets/branding/davidson-left-aligned-lockup-red and white-RGB.png';
import davidsonLogoBlackWhite from '../assets/branding/davidson-left-aligned-lockup-black and white-RGB.png';
import ThemeToggle from '../components/ThemeToggle.svelte';

interface Props {
  title?: string;
}

const { title = 'Data CATS | Davidson College' } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href={withBase('favicon-32x32.png')} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script is:inline>
      // Applied on first load, and again to the incoming document during
      // Astro's view-transition swap (`astro:before-swap` fires before the new
      // <html> replaces the old one, which otherwise drops the class we set
      // here — the swap doesn't carry over attributes added by client JS).
      // ThemeToggle.svelte reads this same class.
      function applyTheme(doc) {
        const stored = localStorage.getItem('theme');
        const dark = stored ? stored === 'dark' : window.matchMedia('(prefers-color-scheme: dark)').matches;
        doc.documentElement.classList.toggle('dark', dark);
      }
      applyTheme(document);
      document.addEventListener('astro:before-swap', (event) => applyTheme(event.newDocument));
    </script>
    <ClientRouter />
    <script>
      // "Previous"/"Next" consultant links carry data-direction so the swipe
      // animation goes the way the user actually navigated, not always forward.
      document.addEventListener('astro:before-preparation', (event) => {
        const source = event.sourceElement;
        if (source instanceof HTMLElement && source.dataset.direction) {
          event.direction = source.dataset.direction === 'prev' ? 'back' : 'forward';
        }
      });
    </script>
  </head>
  <body class="flex min-h-screen flex-col bg-slate-50 text-slate-900 dark:bg-neutral-900 dark:text-neutral-100">
    <header class="bg-davidson-red">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
        <a href={withBase('')} class="text-lg font-bold tracking-tight text-white">Data CATS</a>
        <div class="flex items-center gap-6 text-sm font-medium text-white">
          <a href={withBase('')} class="hover:text-cool-gray-1">Consultants</a>
          <a href={withBase('calendar')} class="hover:text-cool-gray-1">Calendar</a>
          <a href={withBase('about')} class="hover:text-cool-gray-1">About</a>
          <ThemeToggle client:load />
        </div>
      </nav>
    </header>
    <main class="mx-auto max-w-6xl flex-1 px-6 py-10" transition:animate="slide">
      <slot />
    </main>
    <footer class="bg-davidson-black dark:bg-davidson-red">
      <div class="mx-auto flex max-w-6xl flex-col items-center gap-3 px-6 py-6 text-center text-sm text-white">
        <Image src={davidsonLogoRedWhite} alt="Davidson College" height={32} class="h-8 w-auto dark:hidden" />
        <Image src={davidsonLogoBlackWhite} alt="Davidson College" height={32} class="hidden h-8 w-auto dark:block" />
        <p>Site built and managed by Prof. Pete Benbow and the Data CATS team.</p>
        <a
          href="https://github.com/DavidsonCollege-DataCATS/DataCATS-site"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 text-white hover:underline"
        >
          <Icon name="simple-icons:github" class="h-4 w-4" />
          View source & report issues on GitHub
        </a>
      </div>
    </footer>
  </body>
</html>
