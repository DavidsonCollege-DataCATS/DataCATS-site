---
import '../styles/global.css';
import { Image } from 'astro:assets';
import { ClientRouter } from 'astro:transitions';
import davidsonLogo from '../assets/branding/davidson-left-aligned-lockup-black and white-RGB.png';

interface Props {
  title?: string;
}

const { title = 'Data CATS | Davidson College' } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ClientRouter />
    <script>
      // "Previous"/"Next" consultant links carry data-direction so the swipe
      // animation goes the way the user actually navigated, not always forward.
      document.addEventListener('astro:before-preparation', (event) => {
        const source = event.sourceElement;
        if (source instanceof HTMLElement && source.dataset.direction) {
          event.direction = source.dataset.direction === 'prev' ? 'back' : 'forward';
        }
      });
    </script>
  </head>
  <body class="flex min-h-screen flex-col bg-slate-50 text-slate-900">
    <header class="bg-davidson-red">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
        <a href="/" class="flex items-center gap-3">
          <Image src={davidsonLogo} alt="Davidson College" height={32} class="h-8 w-auto" />
          <span class="text-lg font-bold tracking-tight text-white">Data CATS</span>
        </a>
        <div class="flex gap-6 text-sm font-medium text-white">
          <a href="/" class="hover:text-cool-gray-1">Consultants</a>
          <a href="/calendar" class="hover:text-cool-gray-1">Calendar</a>
        </div>
      </nav>
    </header>
    <main class="mx-auto max-w-6xl flex-1 px-6 py-10" transition:animate="slide">
      <slot />
    </main>
    <footer class="bg-davidson-black">
      <div class="mx-auto max-w-6xl px-6 py-6 text-center text-sm text-white">
        Site built and managed by Prof. Pete Benbow and the Data CATS team.
      </div>
    </footer>
  </body>
</html>
