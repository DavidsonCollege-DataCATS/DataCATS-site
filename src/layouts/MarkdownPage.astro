---
import Layout from './Layout.astro';

interface Props {
  frontmatter: {
    title?: string;
  };
}

const { frontmatter } = Astro.props;
---

<Layout title={frontmatter.title}>
  <article class="prose prose-slate max-w-3xl prose-headings:text-slate-900 prose-a:text-davidson-red prose-a:no-underline hover:prose-a:underline">
    <slot />
  </article>
</Layout>
