---
interface Props {
  coursework: { course: string; professor?: string; term?: string }[];
}

const { coursework } = Astro.props;
---

{coursework.length > 0 && (
  <div>
    <table class="hidden w-full border-collapse text-left text-sm md:table">
      <thead>
        <tr class="border-b border-slate-200 text-xs font-semibold uppercase tracking-wide text-slate-500">
          <th class="py-2 pr-4">Course</th>
          <th class="py-2 pr-4">Professor</th>
          <th class="py-2">Term</th>
        </tr>
      </thead>
      <tbody>
        {coursework.map((cw) => (
          <tr class="border-b border-slate-100 last:border-0 hover:bg-slate-50">
            <td class="py-2 pr-4 font-medium text-slate-900">{cw.course}</td>
            <td class="py-2 pr-4 text-slate-600">{cw.professor ?? '—'}</td>
            <td class="py-2">
              {cw.term && (
                <span class="rounded-full bg-lake-blue/10 px-2 py-0.5 text-xs font-medium text-lake-blue">{cw.term}</span>
              )}
            </td>
          </tr>
        ))}
      </tbody>
    </table>

    <ul class="space-y-2 md:hidden">
      {coursework.map((cw) => (
        <li class="rounded-lg border border-slate-200 p-3">
          <p class="font-medium text-slate-900">{cw.course}</p>
          {(cw.professor || cw.term) && (
            <p class="mt-1 flex items-center gap-2 text-sm text-slate-600">
              {cw.professor && <span>{cw.professor}</span>}
              {cw.term && (
                <span class="rounded-full bg-lake-blue/10 px-2 py-0.5 text-xs font-medium text-lake-blue">{cw.term}</span>
              )}
            </p>
          )}
        </li>
      ))}
    </ul>
  </div>
)}
