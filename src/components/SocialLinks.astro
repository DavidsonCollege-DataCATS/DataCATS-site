---
import { Icon } from 'astro-icon/components';

interface Props {
  socials: {
    linkedin?: string;
    github?: string;
    instagram?: string;
    website?: string;
  };
  name: string;
}

const { socials, name } = Astro.props;

const links = [
  { key: 'linkedin', href: socials.linkedin, icon: 'simple-icons:linkedin', label: `${name} on LinkedIn` },
  { key: 'github', href: socials.github, icon: 'simple-icons:github', label: `${name} on GitHub` },
  { key: 'instagram', href: socials.instagram, icon: 'simple-icons:instagram', label: `${name} on Instagram` },
  { key: 'website', href: socials.website, icon: 'heroicons:globe-alt', label: `${name}'s website` },
].filter((link) => link.href);
---

{links.length > 0 && (
  <div class="mt-3 flex gap-3">
    {links.map((link) => (
      <a
        href={link.href}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={link.label}
        class="text-slate-500 hover:text-davidson-red dark:text-slate-400 dark:hover:text-davidson-red-light"
      >
        <Icon name={link.icon} class="h-5 w-5" />
      </a>
    ))}
  </div>
)}
