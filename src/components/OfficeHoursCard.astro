---
import { Icon } from 'astro-icon/components';
---

<div class="mb-8 rounded-xl border border-slate-200 bg-white p-5 shadow-sm dark:border-neutral-700 dark:bg-neutral-800">
  <h2 class="text-xl font-semibold text-slate-900 dark:text-neutral-100">Drop-in office hours</h2>
  <div class="mt-3 flex flex-col gap-3 text-lg text-slate-700 dark:text-neutral-300 sm:flex-row sm:gap-8">
    <p class="flex items-center gap-2">
      <Icon name="heroicons:map-pin-solid" class="h-6 w-6 text-davidson-red" />
      Chambers 3146
    </p>
    <p class="flex items-center gap-2">
      <Icon name="heroicons:calendar-days-solid" class="h-6 w-6 text-davidson-red" />
      <b>Every Sunday thru Thursday</b> while classes are in session
    </p>
    <p class="flex items-center gap-2">
      <Icon name="heroicons:clock-solid" class="h-6 w-6 text-davidson-red" />
      2:00 - 4:00 PM <br> 7:00 - 9:00 PM
    </p>
  </div>
  <p class="mt-3 text-base text-slate-500 dark:text-neutral-400">
    Some consultants also take appointments outside these hours. Check their individual profiles for availability.
  </p>
</div>
