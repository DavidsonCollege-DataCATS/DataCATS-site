---
import { getCollection } from 'astro:content';
import { getImage } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import ConsultantGrid from '../components/ConsultantGrid.svelte';
import { majorMinorLabel, allMajors } from '../lib/consultant';
import { withBase } from '../lib/url';

const entries = (await getCollection('consultants')).filter((e) => e.data.active);

const consultants = await Promise.all(
  entries.map(async (entry) => {
    const optimized = await getImage({ src: entry.data.headshot, width: 400, height: 400 });
    return {
      slug: entry.id,
      name: entry.data.name,
      headshotSrc: optimized.src,
      classYear: entry.data.classYear,
      majorMinorLabel: majorMinorLabel(entry.data),
      majorsForFilter: allMajors(entry.data),
      skillAreas: entry.data.skillAreas,
      tools: entry.data.tools,
      coursework: entry.data.coursework,
      languages: entry.data.languages,
    };
  }),
);

consultants.sort((a, b) => a.name.localeCompare(b.name));

const facultyEntries = (await getCollection('faculty')).filter((e) => e.data.active);
const faculty = await Promise.all(
  facultyEntries.map(async (entry) => {
    const optimized = await getImage({ src: entry.data.headshot, width: 400, height: 400 });
    return {
      slug: entry.id,
      name: entry.data.name,
      headshotSrc: optimized.src,
      department: entry.data.department,
      skillAreas: entry.data.skillAreas,
      tools: entry.data.tools,
    };
  }),
);
---

<Layout>
  <div class="mb-8">
    <h1 class="text-3xl font-bold tracking-tight text-slate-900">Meet the Data CATS</h1>
    <p class="mt-2 max-w-2xl text-slate-600">
      Browse our consultants below, and click to view their profiles and availability.
    </p>
  </div>
  <ConsultantGrid client:load consultants={consultants} />

  {faculty.length > 0 && (
    <div class="mt-16">
      <h2 class="text-2xl font-bold tracking-tight text-slate-900">Faculty</h2>
      <div class="mt-6 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {faculty.map((person) => (
          <a
            href={withBase(`faculty/${person.slug}`)}
            class="group block overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-md"
          >
            <div class="aspect-square w-full overflow-hidden bg-slate-100">
              <img
                src={person.headshotSrc}
                alt={person.name}
                class="h-full w-full object-cover transition duration-300 group-hover:scale-105"
                style={`view-transition-name: headshot-${person.slug}`}
              />
            </div>
            <div class="p-4">
              <h3 class="font-semibold text-slate-900">{person.name}</h3>
              <p class="text-sm text-slate-700">{person.department}</p>
              {(person.skillAreas.length > 0 || person.tools.length > 0) && (
                <div class="mt-2 flex flex-wrap gap-1.5">
                  {person.skillAreas.map((skillArea) => (
                    <span class="rounded-full bg-lake-blue/10 px-2 py-0.5 text-xs font-medium text-lake-blue">{skillArea}</span>
                  ))}
                  {person.tools.map((tool) => (
                    <span class="rounded-full bg-davidson-red/10 px-2 py-0.5 text-xs font-medium text-davidson-red-deep">{tool}</span>
                  ))}
                </div>
              )}
            </div>
          </a>
        ))}
      </div>
    </div>
  )}
</Layout>
