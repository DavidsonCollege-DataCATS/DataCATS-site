---
import { getCollection, render } from 'astro:content';
import { getImage } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import Layout from '../../layouts/Layout.astro';
import ConsultantSchedule from '../../components/ConsultantSchedule.svelte';
import SocialLinks from '../../components/SocialLinks.astro';
import ScheduleButton from '../../components/ScheduleButton.svelte';
import { meetingModeIcons } from '../../lib/meetingModes';
import { countryFlagUrl } from '../../lib/countryFlags';
import availabilityRaw from '../../data/availability.json';
import recurringAvailabilityRaw from '../../data/recurringAvailability.json';

export async function getStaticPaths() {
  const entries = await getCollection('faculty');
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { data } = entry;
const { Content } = await render(entry);

const optimized = await getImage({ src: data.headshot, width: 500, height: 500 });
const events = availabilityRaw
  .filter((e) => e.slug === entry.id)
  .map((e) => ({ ...e, name: data.name }));
const recurringEvents = recurringAvailabilityRaw
  .filter((e) => e.slug === entry.id)
  .map((e) => ({ ...e, name: data.name }));
const flagUrl = countryFlagUrl(data.homeCountry);
---

<Layout title={`${data.name} | Data CATS`}>
  <div class="grid gap-8 md:grid-cols-[280px_1fr]">
    <div>
      <img
        src={optimized.src}
        alt={data.name}
        class="aspect-square w-full rounded-xl object-cover shadow-sm"
        style={`view-transition-name: headshot-${entry.id}`}
      />
      <h1 class="mt-4 text-2xl font-bold text-slate-900">
        {data.name}
        {data.pronouns && <span class="ml-2 text-base font-normal text-slate-500">({data.pronouns})</span>}
      </h1>
      <p class="mt-1 font-medium text-slate-700">{data.department}</p>
      {data.office && (
        <p class="mt-3 flex items-center gap-1.5 text-sm text-slate-600">
          <Icon name="heroicons:map-pin-solid" class="h-5 w-5 text-davidson-red" />
          {data.office}
        </p>
      )}
      {data.email && (
        <p class="mt-1 flex items-center gap-1.5 text-sm text-slate-600">
          <Icon name="heroicons:envelope-solid" class="h-5 w-5 text-davidson-red" />
          <a href={`mailto:${data.email}`} class="text-davidson-red hover:underline">{data.email}</a>
        </p>
      )}
      <p class="mt-1 flex items-center gap-1.5 text-sm text-slate-600">
        <Icon name="heroicons:globe-alt-solid" class="h-5 w-5 text-davidson-red" />
        {data.homeCountry}
        {flagUrl && <img src={flagUrl} alt="" class="inline h-4 w-5" />}
      </p>
      <p class="mt-1 flex items-center gap-1.5 text-sm text-slate-600">
        <Icon name="heroicons:chat-bubble-left-right-solid" class="h-5 w-5 text-davidson-red" />
        {data.languages.join(', ')}
      </p>
      <p class="mt-1 flex items-center gap-3 text-sm text-slate-600">
        {data.meetingModes.map((mode) => (
          <span class="flex items-center gap-1.5">
            <Icon name={meetingModeIcons[mode].icon} class="h-5 w-5 text-davidson-red" />
            {meetingModeIcons[mode].label}
          </span>
        ))}
      </p>
      <SocialLinks socials={data.socials} name={data.name} />
      <ScheduleButton client:load consultantName={data.name} zoomSchedulerUrl={data.zoomSchedulerUrl ?? ''} />
    </div>

    <div class="space-y-8">
      <section>
        <h2 class="text-lg font-semibold text-slate-900">About</h2>
        <div class="mt-2 max-w-none text-slate-700">
          <Content />
        </div>
      </section>

      <section>
        <h2 class="text-lg font-semibold text-slate-900">Skill inventory</h2>
        <div class="mt-2 flex flex-wrap gap-2">
          {data.skillAreas.map((skillArea) => (
            <span class="rounded-full bg-lake-blue/10 px-3 py-1 text-sm font-medium text-lake-blue">{skillArea}</span>
          ))}
          {data.tools.map((tool) => (
            <span class="rounded-full bg-davidson-red/10 px-3 py-1 text-sm font-medium text-davidson-red-deep">{tool}</span>
          ))}
        </div>
      </section>

      {data.coursework.length > 0 && (
        <section>
          <h2 class="text-lg font-semibold text-slate-900">Courses I teach</h2>
          <ul class="mt-2 list-inside list-disc text-slate-700">
            {data.coursework.map((course) => <li>{course}</li>)}
          </ul>
        </section>
      )}

      {data.experience.length > 0 && (
        <section>
          <h2 class="text-lg font-semibold text-slate-900">Experience</h2>
          <ul class="mt-2 space-y-3">
            {data.experience.map((job) => (
              <li>
                <p class="font-medium text-slate-900">{job.title} — {job.organization}</p>
                {job.dates && <p class="text-sm text-slate-500">{job.dates}</p>}
                {job.description && <p class="text-sm text-slate-600">{job.description}</p>}
              </li>
            ))}
          </ul>
        </section>
      )}

      <section>
        <h2 class="text-lg font-semibold text-slate-900">Availability</h2>
        <p class="mt-1 text-sm text-slate-500">Click an open slot to book time with {data.name}.</p>
        <div class="mt-2">
          <ConsultantSchedule
            client:load
            {events}
            {recurringEvents}
            consultantName={data.name}
            zoomSchedulerUrl={data.zoomSchedulerUrl ?? ''}
          />
        </div>
      </section>
    </div>
  </div>
</Layout>
