---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import TeamCalendar from '../components/TeamCalendar.svelte';
import { allMajors } from '../lib/consultant';
import availabilityRaw from '../data/availability.json';
import recurringAvailabilityRaw from '../data/recurringAvailability.json';

const entries = (await getCollection('consultants')).filter((e) => e.data.active);
const facultyEntries = (await getCollection('faculty')).filter((e) => e.data.active);

const consultants = entries.map((entry) => ({
  slug: entry.id,
  name: entry.data.name,
  skillAreas: entry.data.skillAreas,
  tools: entry.data.tools,
  majorsForFilter: allMajors(entry.data),
  coursework: entry.data.coursework,
  languages: entry.data.languages,
}));

// Faculty aren't filterable from the team calendar's dropdowns (those are scoped to
// student consultants' majors/coursework), but their name should still resolve
// correctly for events tied to their slug (e.g. standing faculty office hours).
const nameBySlug = new Map([
  ...consultants.map((c) => [c.slug, c.name]),
  ...facultyEntries.map((e) => [e.id, e.data.name]),
]);
const events = availabilityRaw.map((e) => ({ ...e, name: nameBySlug.get(e.slug) ?? e.slug }));
const recurringEvents = recurringAvailabilityRaw.map((e) => ({ ...e, name: nameBySlug.get(e.slug) ?? e.slug }));
---

<Layout title="Team Calendar | Data CATS">
  <div class="mb-8">
    <h1 class="text-3xl font-bold tracking-tight text-slate-900 dark:text-neutral-100">Team Calendar</h1>
    <p class="mt-2 max-w-2xl text-slate-600 dark:text-neutral-400">
      Browse upcoming office hours and appointment blocks across the whole Data CATS team. Filter by skill area, tool,
      major, coursework, language, or an individual consultant.
    </p>
  </div>
  <TeamCalendar client:load {events} {recurringEvents} {consultants} />
</Layout>
